# Supabase — ambil dari Supabase Studio → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxx
NEXT_PUBLIC_APP_ENV=development

# Google Gemini (fitur ekstraksi KK) — SERVER-ONLY, JANGAN pakai prefix NEXT_PUBLIC_
# Ambil API key GRATIS di https://aistudio.google.com/apikey . Set juga di Vercel env saat deploy.
GEMINI_API_KEY=xxxxx
# Opsional: ganti model bila perlu (default gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
